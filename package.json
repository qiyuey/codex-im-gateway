{
  "name": "codex-im-gateway",
  "version": "0.1.0",
  "description": "Local-first Codex plugin for durable IM notifications and thread replies",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0"
  },
  "bin": {
    "codex-im-gateway": "dist/cli.js",
    "codex-im-gateway-daemon": "dist/daemon.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm smoke:dist && pnpm validate:plugin",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "protocol:generate": "node scripts/generate-protocol.mjs",
    "start": "node --env-file-if-exists=.env dist/daemon.js",
    "smoke:dist": "node scripts/smoke-dist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:plugin": "node scripts/validate-plugin.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "grammy": "^1.44.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
